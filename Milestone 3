    conn.close()

def get_all_feedback():
    conn = sqlite3.connect(DB_NAME)
    c = conn.cursor()
    c.execute("SELECT id, email, feature, rating, comments, created_at FROM feedback ORDER BY created_at DESC")
    feedback = c.fetchall()
    conn.close()
    return feedback

