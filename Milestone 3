    msg['To'] = email
    msg['Subject'] = "Your OTP Login Code"

    body = f"Your OTP code is {otp}. It will expire in {OTP_EXPIRY_MINUTES} minutes."
    msg.attach(MIMEText(body, 'plain'))

    server = smtplib.SMTP('smtp.gmail.com', 587)
