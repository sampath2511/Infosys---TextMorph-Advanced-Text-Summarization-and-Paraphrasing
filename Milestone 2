def login_view():
    st.markdown("<h1>卐 TextMorph</h1>", unsafe_allow_html=True)
    st.markdown("<p style='text-align: center; color: #555;'>Sign in to continue</p>", unsafe_allow_html=True)

    # Show success message if user just created an account
